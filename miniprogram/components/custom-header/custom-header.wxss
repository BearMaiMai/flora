/* components/custom-header/custom-header.wxss - 公共顶部标题样式 */
.custom-header-wrap {
  flex-shrink: 0;
  background-color: var(--bg-page, #F8FBF5);
}

.custom-header {
  padding: 16rpx 32rpx 24rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--text-primary, #1a1a1a);
  line-height: 1.2;
}

.app-subtitle-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.subtitle-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: var(--color-primary, #4CAF50);
  margin-right: 10rpx;
}

.app-subtitle {
  font-size: 24rpx;
  color: var(--color-primary, #4CAF50);
  font-weight: 500;
  letter-spacing: 2rpx;
}

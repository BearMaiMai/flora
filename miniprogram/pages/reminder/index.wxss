/* pages/reminder/index.wxss - 养护提醒页样式 */
.reminder-page {
  padding: 24rpx 24rpx 48rpx;
}

/* 页面头部 */
.page-header {
  margin-bottom: 24rpx;
}

.page-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--text-primary);
}

.reminder-count-badge {
  background-color: var(--color-accent);
  color: white;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: var(--border-radius-round);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 10rpx;
}

.page-subtitle {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
  padding: 4rpx 0;
}

.filter-tab {
  padding: 12rpx 28rpx;
  border-radius: var(--border-radius-round);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background-color: var(--bg-card);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.filter-tab.active {
  background-color: var(--color-primary);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

/* Timeline 样式 */
.timeline-list {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 0;
}

.timeline-item.item-done {
  opacity: 0.6;
}

/* 时间线左侧 */
.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 32rpx;
}

.dot-upcoming {
  background-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(76, 175, 80, 0.15);
}

.dot-overdue {
  background-color: var(--color-accent);
  box-shadow: 0 0 0 6rpx rgba(255, 112, 67, 0.15);
}

.dot-done {
  background-color: var(--text-hint);
}

.timeline-line {
  width: 3rpx;
  flex: 1;
  background: linear-gradient(180deg, var(--color-primary-light), var(--border-color));
  margin: 8rpx 0;
  min-height: 40rpx;
}

/* 内容卡片 */
.timeline-card {
  flex: 1;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.timeline-card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reminder-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.reminder-avatar-mini {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--bg-green-light);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.reminder-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.reminder-plant-name {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.text-line-through {
  text-decoration: line-through;
  color: var(--text-hint);
}

.reminder-tags-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.reminder-type-tag {
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: var(--border-radius-round);
  font-weight: 500;
}

.type-water {
  background-color: var(--bg-blue-light);
  color: #1565C0;
}

.type-fertilizer {
  background-color: var(--bg-green-light);
  color: var(--color-primary-dark);
}

.type-other {
  background-color: var(--bg-yellow-light);
  color: #F57F17;
}

.reminder-time-text {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.reminder-next-time {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* 打勾按钮 */
.check-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: var(--font-md);
  color: var(--text-hint);
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.check-circle.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: white;
}

.check-circle:active {
  transform: scale(0.9);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

<!--pages/reminder/index.wxml - 养护提醒-->
<view class="container reminder-page">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="page-title-row">
      <text class="page-title">养护提醒</text>
      <view class="reminder-count-badge" wx:if="{{reminderList.length}}">{{reminderList.length}}</view>
    </view>
    <text class="page-subtitle">共 {{pendingCount}} 条待完成</text>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="all">全部</view>
    <view class="filter-tab {{currentFilter === 'today' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="today">今日</view>
    <view class="filter-tab {{currentFilter === 'pending' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="pending">待完成</view>
    <view class="filter-tab {{currentFilter === 'done' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="done">已完成</view>
  </view>

  <!-- 提醒列表 (Timeline 样式) -->
  <view class="timeline-list anim-fade-in-up anim-delay-2" wx:if="{{filteredList.length}}">
    <view class="timeline-item {{item.done ? 'item-done' : ''}}" wx:for="{{filteredList}}" wx:key="_id">
      <!-- 时间线 -->
      <view class="timeline-left">
        <view class="timeline-dot {{item.done ? 'dot-done' : item.overdue ? 'dot-overdue' : 'dot-upcoming'}}"></view>
        <view class="timeline-line" wx:if="{{index < filteredList.length - 1}}"></view>
      </view>
      <!-- 内容卡片 -->
      <view class="timeline-card">
        <view class="timeline-card-main">
          <view class="reminder-content">
            <view class="reminder-avatar-mini">
              <icon emoji="{{item.icon}}" size="md" />
            </view>
            <view class="reminder-info">
              <text class="reminder-plant-name {{item.done ? 'text-line-through' : ''}}">{{item.plantName}}</text>
              <view class="reminder-tags-row">
                <text class="reminder-type-tag {{item.type === '浇水' ? 'type-water' : item.type === '施肥' ? 'type-fertilizer' : 'type-other'}}">{{item.type}}</text>
                <text class="reminder-time-text">{{item.time}}</text>
              </view>
              <text class="reminder-next-time">⏰ {{item.nextTime}}</text>
            </view>
          </view>
          <view class="check-circle {{item.done ? 'checked' : ''}}" bindtap="onComplete" data-id="{{item._id}}">
            <icon wx:if="{{item.done}}" name="check" size="xs" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !filteredList.length}}">
    <icon name="lavender" size="xl" />
    <text class="empty-text">暂无提醒</text>
    <text class="empty-subtext">添加植物后会自动生成养护提醒哦</text>
  </view>
</view>

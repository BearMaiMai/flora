/* pages/encyclopedia/index.wxss - 花卉百科列表页样式 */
.container { padding: 24rpx; }

.search-bar {
  background-color: var(--bg-grey);
  border-radius: var(--border-radius-round);
  padding: 16rpx 32rpx;
  margin-bottom: 24rpx;
}

.search-input {
  font-size: var(--font-md);
  width: 100%;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: var(--border-radius-round);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background-color: var(--bg-grey);
}

.category-item.active {
  background-color: var(--color-primary);
  color: var(--text-white);
}

.list-count {
  font-size: var(--font-xs);
  margin-bottom: 16rpx;
}

.flower-item {
  display: flex;
  flex-direction: row;
  padding: 0;
  overflow: hidden;
}

.flower-cover {
  width: 160rpx;
  min-height: 160rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.flower-emoji {
  font-size: 60rpx;
}

.flower-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.flower-name-row {
  margin-bottom: 4rpx;
}

.flower-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.flower-difficulty {
  font-size: var(--font-xs);
}

.flower-cat {
  font-size: var(--font-xs);
  display: block;
  margin-bottom: 4rpx;
}

.flower-desc {
  font-size: var(--font-sm);
  line-height: 1.4;
}

.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-hint);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

/* pages/encyclopedia/index.wxss - 花卉百科列表页样式 */
.encyclopedia-page {
  padding: 0 24rpx 48rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--bg-grey);
  border-radius: var(--border-radius-round);
  padding: 18rpx 28rpx;
  margin-bottom: 24rpx;
}

.search-icon-wrap {
  margin-right: 12rpx;
}

.search-icon-text {
  font-size: 28rpx;
}

.search-input {
  font-size: var(--font-md);
  flex: 1;
}

/* 分类筛选 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding: 4rpx 0;
}

.category-item {
  display: inline-block;
  padding: 14rpx 32rpx;
  margin-right: 16rpx;
  border-radius: var(--border-radius-round);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background-color: var(--bg-card);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.category-item.active {
  background-color: var(--color-primary);
  color: var(--text-white);
  box-shadow: var(--shadow-btn);
}

/* 统计 */
.list-count {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.list-count-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.list-count-text {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.list-count-num {
  font-weight: 600;
  color: var(--color-primary);
}

/* 花卉列表 - 与首页推荐卡片风格一致 */
.flower-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.flower-card {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast);
}

.flower-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.flower-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--border-radius-md);
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  background-color: var(--bg-green-light);
}

.thumb-emoji {
  font-size: 64rpx;
}

.flower-info {
  flex: 1;
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.flower-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.flower-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.flower-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--border-radius-round);
  font-weight: 500;
}

/* 分类标签颜色 - 复用全局 tag 变量 */
.tag-green {
  color: var(--color-primary-dark);
  background-color: var(--bg-green-light);
}

.tag-orange {
  color: #E65100;
  background-color: var(--bg-orange-light);
}

.tag-pink {
  color: #AD1457;
  background-color: var(--bg-pink-light);
}

.tag-purple {
  color: #6A1B9A;
  background-color: var(--bg-purple-light);
}

.tag-blue {
  color: #1565C0;
  background-color: var(--bg-blue-light);
}

.flower-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flower-meta {
  display: flex;
  align-items: center;
}

.meta-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.star {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.star.filled {
  color: var(--color-primary);
}

.star.empty {
  color: var(--border-color);
}

.flower-arrow {
  font-size: 40rpx;
  color: var(--text-hint);
  font-weight: 300;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 160rpx 0;
  color: var(--text-hint);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-hint);
}

/* pages/garden/index.wxss - 花园页样式 */
@import '/styles/animation.wxss';

.garden-page {
  padding: 0 24rpx 48rpx;
}

/* 今日待办卡片 */
.tasks-card {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: var(--border-radius-xl);
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.tasks-card::after {
  content: '';
  position: absolute;
  right: -20rpx;
  top: -20rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 152, 0, 0.08);
}

.tasks-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.tasks-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tasks-icon {
  font-size: 32rpx;
}

.tasks-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.tasks-badge {
  background-color: var(--color-accent);
  color: white;
  font-size: var(--font-xs);
  font-weight: 600;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.task-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.task-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-plant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
}

.task-info {
  display: flex;
  flex-direction: column;
}

.task-plant-name {
  font-size: var(--font-md);
  font-weight: 500;
  color: #3E2723;
}

.task-type-time {
  font-size: var(--font-xs);
  color: #795548;
  margin-top: 4rpx;
}

.task-check-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-primary);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: var(--font-md);
  color: var(--color-primary);
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.task-check-btn.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: white;
}

/* 我的植物区块 */
.section {
  margin-top: 8rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.count-badge {
  background-color: var(--bg-green-light);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: var(--border-radius-round);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: var(--color-primary);
  font-size: var(--font-sm);
  padding: 8rpx 20rpx;
  border-radius: var(--border-radius-round);
  background-color: var(--bg-green-light);
}

.add-icon {
  font-size: var(--font-lg);
  font-weight: 300;
}

.add-text {
  font-weight: 500;
}

/* 植物卡片列表 */
.plant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plant-card {
  display: flex;
  flex-direction: row;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  padding: 24rpx;
  border-left: 6rpx solid transparent;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast), background-color var(--transition-fast);
}

.plant-card:active {
  box-shadow: var(--shadow-md);
}

.plant-card-ok {
  border-left-color: var(--color-primary);
}

.plant-card-warn {
  border-left-color: var(--color-warning);
}

/* 植物头像 */
.plant-avatar-wrap {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
}

.plant-avatar-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 4rpx solid transparent;
}

.avatar-ok {
  background-color: var(--bg-green-light);
  border-color: var(--color-primary-light);
}

.avatar-warn {
  background-color: #FFF3E0;
  border-color: var(--color-warning);
}

.plant-emoji {
  font-size: 48rpx;
}

/* 植物信息 */
.plant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.plant-header {
  margin-bottom: 6rpx;
}

.plant-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.plant-status-badge {
  font-size: var(--font-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--border-radius-round);
  font-weight: 500;
}

.badge-ok {
  background-color: var(--bg-green-light);
  color: var(--color-primary-dark);
}

.badge-warn {
  background-color: var(--bg-orange-light);
  color: #E65100;
}

.plant-flower-name {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-bottom: 8rpx;
  display: block;
}

.plant-meta-row {
  display: flex;
  gap: 24rpx;
}

.plant-meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.plant-days,
.plant-water {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: var(--text-hint);
  margin-bottom: 32rpx;
  font-size: var(--font-md);
}

<!--pages/garden/index.wxml - 我的花园-->
<view class="page-layout">
  <!-- 公共标题组件 -->
  <custom-header></custom-header>

  <!-- 骨架屏 -->
  <skeleton type="garden" loading="{{loading}}" />

  <!-- 可滚动内容区 -->
  <scroll-view class="page-content" scroll-y enhanced show-scrollbar="{{false}}" bounces="{{true}}" enable-back-to-top wx:if="{{!loading}}">
    <view class="garden-page">

  <!-- 今日待办 -->
  <view class="tasks-card" wx:if="{{todayReminders.length}}">
    <view class="tasks-header">
      <view class="tasks-title-row">
        <icon name="clipboard" size="md" />
        <text class="tasks-title">今日待办</text>
      </view>
      <view class="tasks-badge">{{todayReminders.length}}</view>
    </view>
    <view class="tasks-list">
      <view class="task-item anim-fade-in-up anim-delay-{{index + 1}}" wx:for="{{todayReminders}}" wx:key="_id">
        <view class="task-left">
          <view class="task-plant-avatar">
            <icon emoji="{{item.icon}}" size="md" />
          </view>
          <view class="task-info">
            <text class="task-plant-name">{{item.plantName}}</text>
            <text class="task-type-time">{{item.type}} · {{item.time}}</text>
          </view>
        </view>
        <view class="task-check-btn {{item.done ? 'checked anim-check-bounce' : ''}}" bindtap="onCompleteReminder" data-id="{{item._id}}" hover-class="hover-icon" hover-stay-time="100">
          <icon name="check" size="xs" />
        </view>
      </view>
    </view>
  </view>

  <!-- 我的植物 -->
  <view class="section anim-fade-in-up anim-delay-2">
    <view class="section-header flex-between">
      <view class="section-title-row">
        <text class="section-title">我的植物</text>
        <view class="count-badge" wx:if="{{plantList.length}}">{{plantList.length}}</view>
      </view>
      <view class="add-btn" bindtap="goToAddPlant">
        <icon name="add" size="sm" color="var(--color-primary)" />
        <text class="add-text">添加</text>
      </view>
    </view>

    <view class="plant-list" wx:if="{{plantList.length}}">
      <view class="plant-card {{item.status === 'needCare' ? 'plant-card-warn' : 'plant-card-ok'}}" wx:for="{{plantList}}" wx:key="_id" bindtap="goToPlantDetail" data-id="{{item._id}}">
        <view class="plant-avatar-wrap">
          <view class="plant-avatar-circle {{item.status === 'needCare' ? 'avatar-warn' : 'avatar-ok'}}">
            <text class="plant-emoji">{{item.status === 'needCare' ? '🌻' : '🌿'}}</text>
          </view>
        </view>
        <view class="plant-info">
          <view class="plant-header flex-between">
            <text class="plant-name">{{item.nickname}}</text>
            <text class="plant-status-badge {{item.status === 'needCare' ? 'badge-warn' : 'badge-ok'}}">{{item.status === 'needCare' ? '需关注' : '健康'}}</text>
          </view>
          <text class="plant-flower-name">{{item.flowerName}} · {{item.location}}</text>
          <view class="plant-meta-row">
            <view class="plant-meta-item">
              <icon src="/images/icons/common/date.svg" size="xs" />
              <text class="plant-days">养了 {{item.days}} 天</text>
            </view>
            <view class="plant-meta-item">
              <icon emoji="💧" size="xs" />
              <text class="plant-water">{{item.lastWatered}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <icon name="tree" size="xl" />
      <text class="empty-text">还没有种花哦</text>
      <view class="btn-primary" bindtap="goToAddPlant">去花卉百科添加</view>
    </view>
  </view>
    </view>
  </scroll-view>
</view>

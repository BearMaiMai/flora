<!--pages/garden/plant-detail.wxml - 植物详情页-->
<view class="plant-detail-page" wx:if="{{plant}}">
  <!-- 植物头像区域 -->
  <view class="plant-profile-section">
    <view class="plant-avatar-glow">
      <view class="glow-ring"></view>
      <view class="plant-avatar-large">
        <text class="plant-avatar-emoji">🌿</text>
      </view>
    </view>
    <text class="plant-nickname">{{plant.nickname}}</text>
    <text class="plant-species">{{plant.flowerName}}</text>
    
    <!-- 信息标签 -->
    <view class="plant-info-pills">
      <view class="info-pill">
        <text class="pill-text">📍 {{plant.location}}</text>
      </view>
      <view class="info-pill">
        <text class="pill-text">🗓️ 养了{{plant.days}}天</text>
      </view>
      <view class="info-pill pill-status-{{plant.status}}">
        <text class="pill-text">🌱 {{plant.status === 'healthy' ? '状态良好' : '需要关注'}}</text>
      </view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-mini-card">
      <text class="stat-mini-num">{{stats.waterCount}}</text>
      <text class="stat-mini-label">浇水次数</text>
    </view>
    <view class="stat-mini-card">
      <text class="stat-mini-num">{{stats.diaryCount}}</text>
      <text class="stat-mini-label">日记条数</text>
    </view>
    <view class="stat-mini-card">
      <text class="stat-mini-num">{{stats.healthScore}}</text>
      <text class="stat-mini-label">健康评分</text>
    </view>
  </view>

  <!-- 成长日记 - 时间线设计 -->
  <view class="diary-section">
    <view class="diary-header flex-between">
      <text class="diary-title">📔 成长日记</text>
      <view class="diary-add-btn" bindtap="goToAddDiary">
        <text class="diary-add-icon">+</text>
        <text class="diary-add-text">记录</text>
      </view>
    </view>

    <view class="diary-timeline" wx:if="{{diaryList.length}}">
      <view class="timeline-entry" wx:for="{{diaryList}}" wx:key="_id">
        <view class="entry-timeline-left">
          <view class="entry-dot"></view>
          <view class="entry-line" wx:if="{{index < diaryList.length - 1}}"></view>
        </view>
        <view class="entry-card">
          <view class="entry-date-bubble">{{item.date}}</view>
          <text class="entry-content">{{item.content}}</text>
          <view class="entry-images" wx:if="{{item.images && item.images.length}}">
            <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" class="entry-img" src="{{img}}" mode="aspectFill" />
          </view>
        </view>
      </view>
    </view>

    <view class="diary-empty" wx:else>
      <text class="diary-empty-icon">✏️</text>
      <text class="diary-empty-text">还没有日记，记录一下吧</text>
    </view>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab" bindtap="goToAddDiary">
    <icon name="add" size="lg" color="var(--text-white)" />
  </view>
</view>

<!--pages/garden/plant-detail.wxml-->
<view class="container" wx:if="{{plant}}">
  <!-- 植物信息卡片 -->
  <view class="card plant-header">
    <view class="plant-avatar-lg" style="background-color: #E8F5E9;">
      <text class="plant-emoji-lg">🌿</text>
    </view>
    <text class="plant-name">{{plant.nickname || plant.flowerName}}</text>
    <text class="plant-type text-hint">{{plant.flowerName}}</text>
    <view class="plant-meta-row mt-sm">
      <text class="meta-tag">📍 {{plant.location}}</text>
      <text class="meta-tag">🗓️ 养了 {{plant.days}} 天</text>
      <text class="meta-tag">🌱 {{plant.status === 'healthy' ? '健康' : '需关注'}}</text>
    </view>
  </view>

  <!-- 成长日记 -->
  <view class="section">
    <view class="flex-between mb-md">
      <text class="section-title">📔 成长日记 ({{diaryList.length}})</text>
      <text class="text-green" bindtap="goToAddDiary">+ 记录</text>
    </view>

    <view class="diary-list" wx:if="{{diaryList.length}}">
      <view class="diary-item card" wx:for="{{diaryList}}" wx:key="_id">
        <text class="diary-date text-hint">{{item.date}}</text>
        <text class="diary-content">{{item.content}}</text>
      </view>
    </view>

    <view class="empty-placeholder" wx:else>
      <text>还没有日记，记录一下吧 ✏️</text>
    </view>
  </view>
</view>

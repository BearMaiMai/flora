<!--pages/garden/diary-edit.wxml-->
<view class="container">
  <textarea class="diary-input" placeholder="记录今天的种植心得..." value="{{content}}" bindinput="onContentInput" maxlength="500" auto-height />
  <view class="image-grid mt-md">
    <view class="image-item" wx:for="{{images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill" />
      <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</view>
    </view>
    <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < maxImageCount}}">
      <icon name="add" size="xl" color="var(--text-hint)" />
    </view>
  </view>
  <button class="btn-primary submit-btn mt-lg" bindtap="onSubmit">保存日记</button>
</view>

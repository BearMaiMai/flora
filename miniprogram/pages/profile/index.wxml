<!--pages/profile/index.wxml - 个人中心-->
<view class="page-layout">
  <!-- 公共标题组件 -->
  <custom-header></custom-header>

  <!-- 可滚动内容区 -->
  <scroll-view class="page-content" scroll-y enhanced show-scrollbar="{{false}}" bounces="{{true}}" enable-back-to-top>
    <view class="profile-page">

  <!-- 顶部渐变背景区域 -->
  <view class="profile-header anim-fade-in">
    <view class="header-bg"></view>
    
    <!-- 用户信息 -->
    <view class="user-section" wx:if="{{isLoggedIn}}">
      <view class="avatar-container">
        <view class="avatar-decoration">
          <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" />
          <view wx:else class="avatar-default">
            <text class="avatar-emoji">🧑‍🌾</text>
          </view>
        </view>
      </view>
      <text class="username">{{userInfo.nickName}}</text>
      <view class="user-motto-row">
        <text class="user-motto">用心养花，静待花开</text>
        <icon src="/images/icons/flower/a-023-cherryblossom.svg" size="sm" />
      </view>
    </view>
    <view class="user-section login-section" wx:else bindtap="onLogin">
      <view class="avatar-container">
        <view class="avatar-decoration">
          <view class="avatar-default">
            <text class="avatar-emoji">👋</text>
          </view>
        </view>
      </view>
      <text class="login-text">点击登录</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num font-number">{{stats.plantCount}}</text>
      <text class="stat-label">我的植物</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num font-number">{{stats.diaryCount}}</text>
      <text class="stat-label">成长日记</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num font-number">{{stats.favoriteCount}}</text>
      <text class="stat-label">我的收藏</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToReminder" hover-class="hover-list-item" hover-stay-time="100">
      <view class="menu-left">
        <view class="menu-icon-wrap icon-bell">
          <icon name="bell" size="sm" />
        </view>
        <text class="menu-label">养护提醒</text>
      </view>
      <view class="menu-right">
        <view class="notification-badge" wx:if="{{reminderCount > 0}}">{{reminderCount}}</view>
        <icon name="chevronRight" size="sm" color="var(--text-hint)" />
      </view>
    </view>

    <view class="menu-item" bindtap="goToFavorites" hover-class="hover-list-item" hover-stay-time="100">
      <view class="menu-left">
        <view class="menu-icon-wrap icon-heart">
          <icon name="heart" size="sm" />
        </view>
        <text class="menu-label">我的收藏</text>
      </view>
      <view class="menu-right">
        <icon name="chevronRight" size="sm" color="var(--text-hint)" />
      </view>
    </view>

    <view class="menu-item" bindtap="goToGuide" hover-class="hover-list-item" hover-stay-time="100">
      <view class="menu-left">
        <view class="menu-icon-wrap icon-book">
          <icon name="book" size="sm" />
        </view>
        <text class="menu-label">种植指南</text>
      </view>
      <view class="menu-right">
        <icon name="chevronRight" size="sm" color="var(--text-hint)" />
      </view>
    </view>

    <view class="menu-item" bindtap="goToSettings" hover-class="hover-list-item" hover-stay-time="100">
      <view class="menu-left">
        <view class="menu-icon-wrap icon-settings">
          <icon name="gear" size="sm" />
        </view>
        <text class="menu-label">设置</text>
      </view>
      <view class="menu-right">
        <icon name="chevronRight" size="sm" color="var(--text-hint)" />
      </view>
    </view>

    <view class="menu-item" bindtap="goToAbout" hover-class="hover-list-item" hover-stay-time="100">
      <view class="menu-left">
        <view class="menu-icon-wrap icon-info">
          <icon name="info" size="sm" />
        </view>
        <text class="menu-label">关于养花呀</text>
      </view>
      <view class="menu-right">
        <icon name="chevronRight" size="sm" color="var(--text-hint)" />
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="bottom-spacer safe-bottom"></view>
    </view>
  </scroll-view>
</view>

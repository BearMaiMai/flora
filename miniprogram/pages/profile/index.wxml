<!--pages/profile/index.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="card user-card flex-row" wx:if="{{isLoggedIn}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" />
    <view class="user-info">
      <text class="username">{{userInfo.nickName}}</text>
    </view>
  </view>
  <view class="card user-card flex-center" wx:else bindtap="onLogin">
    <text class="login-text">点击登录 👋</text>
  </view>

  <!-- 统计 -->
  <view class="card stats-card flex-between">
    <view class="stat-item">
      <text class="stat-num">{{stats.plantCount}}</text>
      <text class="stat-label">我的植物</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.diaryCount}}</text>
      <text class="stat-label">成长日记</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.favoriteCount}}</text>
      <text class="stat-label">我的收藏</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="card menu-card">
    <view class="menu-item flex-between" bindtap="goToReminder">
      <text>🔔 养护提醒</text><text class="arrow">></text>
    </view>
    <view class="divider"></view>
    <view class="menu-item flex-between" bindtap="goToFavorites">
      <text>❤️ 我的收藏</text><text class="arrow">></text>
    </view>
    <view class="divider"></view>
    <view class="menu-item flex-between" bindtap="goToAbout">
      <text>ℹ️ 关于养花呀</text><text class="arrow">></text>
    </view>
  </view>
</view>

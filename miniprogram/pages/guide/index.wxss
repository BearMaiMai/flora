/* pages/guide/index.wxss */
.container { padding: 24rpx; }

.page-title {
  font-size: var(--font-xl);
  font-weight: 600;
  margin-bottom: 24rpx;
}

.guide-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.guide-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.guide-info {
  flex: 1;
}

.guide-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.guide-summary {
  display: block;
  font-size: var(--font-sm);
  line-height: 1.4;
}

.guide-arrow {
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.empty-placeholder { text-align: center; padding: 120rpx 0; color: var(--text-hint); }

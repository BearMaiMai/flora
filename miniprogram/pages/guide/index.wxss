/* pages/guide/index.wxss - 种植指南样式 */
.guide-page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background-color: var(--bg-page);
}

/* 页面头部 */
.guide-header {
  margin-bottom: 24rpx;
}

.guide-page-title {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--text-primary);
}

/* 精选指南大图卡片 */
.featured-card {
  border-radius: var(--border-radius-xl);
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-md);
}

.featured-image-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.featured-image-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 50%, #81C784 100%);
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
}

.featured-reading-badge {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  color: var(--text-white);
  font-size: var(--font-xs);
  padding: 6rpx 16rpx;
  border-radius: var(--border-radius-round);
  margin-bottom: 12rpx;
}

.featured-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-white);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.featured-desc {
  display: block;
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.featured-card:active {
  transform: scale(0.98);
}

/* 分类图标 */
.category-section {
  margin-bottom: 36rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
}

.category-circle-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 28rpx;
  width: 100rpx;
}

.category-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 10rpx;
  box-shadow: var(--shadow-sm);
}

.category-emoji {
  font-size: 36rpx;
}

.category-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  text-align: center;
  white-space: nowrap;
}

/* 文章列表 */
.article-section {
  margin-top: 8rpx;
}

.article-section-title {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
}

.article-card:active {
  box-shadow: var(--shadow-md);
}

.article-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--border-radius-md);
  background-color: var(--bg-green-light);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.article-thumb-emoji {
  font-size: 40rpx;
}

.article-info {
  flex: 1;
  min-width: 0;
}

.article-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-summary {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-meta {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.article-difficulty {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--border-radius-round);
  background-color: #FFF3E0;
  color: #E65100;
}

.article-read-time {
  font-size: 20rpx;
  color: var(--text-hint);
}

.article-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.arrow-icon {
  font-size: var(--font-xl);
  color: var(--text-hint);
  font-weight: 300;
}

/* 空状态 */
.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-hint);
}

<!--pages/guide/index.wxml-->
<view class="container">
  <view class="page-title">📖 种植指南</view>
  <view class="guide-list">
    <view class="guide-item card" wx:for="{{guideList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="guide-icon">{{item.icon}}</view>
      <view class="guide-info">
        <text class="guide-title">{{item.title}}</text>
        <text class="guide-summary text-secondary">{{item.summary}}</text>
      </view>
      <text class="guide-arrow text-hint">></text>
    </view>
    <view class="empty-placeholder" wx:if="{{!loading && !guideList.length}}">
      <text>种植指南即将上线 📖</text>
    </view>
  </view>
</view>

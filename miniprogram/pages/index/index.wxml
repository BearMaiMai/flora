<!--pages/index/index.wxml - 首页-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goToEncyclopedia">
    <text class="search-placeholder">🔍 搜索花卉...</text>
  </view>

  <!-- 每日养花小贴士 -->
  <view class="card daily-tip" wx:if="{{dailyTip}}">
    <text class="tip-label">🌱 今日小贴士</text>
    <text class="tip-content">{{dailyTip}}</text>
  </view>

  <!-- 季节养护速览 -->
  <view class="season-tips flex-row" wx:if="{{seasonTips.length}}">
    <view class="season-tip-item card" wx:for="{{seasonTips}}" wx:key="title">
      <text class="season-icon">{{item.icon}}</text>
      <text class="season-title">{{item.title}}</text>
      <text class="season-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 推荐花卉 -->
  <view class="section">
    <view class="section-header flex-between">
      <text class="section-title">推荐花卉</text>
      <text class="section-more text-green" bindtap="goToEncyclopedia">查看更多 ></text>
    </view>
    <view class="recommend-list" wx:if="{{recommendList.length}}">
      <view class="recommend-card card" wx:for="{{recommendList}}" wx:key="_id" bindtap="goToFlowerDetail" data-id="{{item._id}}">
        <view class="recommend-cover" style="background-color: {{item.coverImage ? '' : '#E8F5E9'}};">
          <image wx:if="{{item.coverImage}}" src="{{item.coverImage}}" mode="aspectFill" class="cover-img" />
          <text wx:else class="cover-emoji">🌿</text>
        </view>
        <view class="recommend-info">
          <text class="recommend-name">{{item.name}}</text>
          <text class="recommend-category text-hint">{{item.category}}</text>
          <text class="recommend-desc text-secondary text-ellipsis-2">{{item.description}}</text>
          <view class="difficulty-row mt-sm">
            <text class="difficulty-label text-hint">难度：</text>
            <text class="difficulty-stars">{{item.difficulty === 1 ? '⭐' : item.difficulty === 2 ? '⭐⭐' : '⭐⭐⭐'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-placeholder" wx:else>
      <text>暂无推荐，快去探索花卉百科吧 🌺</text>
    </view>
  </view>
</view>

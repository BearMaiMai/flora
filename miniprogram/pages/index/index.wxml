<!--pages/index/index.wxml - 首页-->
<view class="page-layout">
  <!-- 公共标题组件 -->
  <custom-header></custom-header>

  <!-- 可滚动内容区 -->
  <scroll-view class="page-content" scroll-y enhanced show-scrollbar="{{false}}" bounces="{{true}}" enable-back-to-top>
    <view class="home-page">

      <!-- 搜索栏 -->
      <view class="home-search anim-fade-in-down" bindtap="goToEncyclopedia">
        <view class="home-search-inner">
          <icon name="search" size="sm" />
          <text class="home-search-text">搜索花卉百科...</text>
        </view>
      </view>

      <!-- 每日养护小贴士 -->
      <view class="tip-card anim-fade-in-up anim-delay-1" wx:if="{{dailyTip}}">
        <view class="tip-card-body">
          <view class="tip-card-header">
            <icon name="leaf" size="lg" bg="primary" />
            <text class="tip-card-title">每日养花小贴士</text>
          </view>
          <text class="tip-card-desc">{{dailyTip}}</text>
        </view>
        <view class="tip-card-deco">
          <icon name="plant" size="xl" />
        </view>
      </view>

      <!-- 季节养护 -->
      <view class="section anim-fade-in-up anim-delay-2" wx:if="{{seasonTips.length}}">
        <view class="section-header flex-between">
          <view class="section-title-row">
            <icon name="plant" size="sm" />
            <text class="section-title">季节养护</text>
          </view>
          <view class="section-more-btn" bindtap="goToGuide">
            <text>查看更多</text>
            <icon name="arrow" size="xs" />
          </view>
        </view>
        <view class="season-grid">
          <view
            class="season-card anim-scale-in anim-delay-{{index + 3}}"
            wx:for="{{seasonTips}}"
            wx:key="title"
            style="background: {{item.gradient || item.bgColor}};"
          >
            <view class="season-card-icon-wrap">
              <icon emoji="{{item.icon}}" size="lg" />
            </view>
            <text class="season-card-title">{{item.title}}</text>
            <text class="season-card-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 为你推荐 -->
      <view class="section anim-fade-in-up anim-delay-4">
        <view class="section-header flex-between">
          <view class="section-title-row">
            <icon name="leaf" size="sm" />
            <text class="section-title">为你推荐</text>
          </view>
          <view class="section-more-btn" bindtap="goToEncyclopedia">
            <text>查看更多</text>
            <icon name="arrow" size="xs" />
          </view>
        </view>

        <!-- 推荐列表 -->
        <view class="recommend-list" wx:if="{{recommendList.length}}">
          <view
            class="recommend-card anim-fade-in-up anim-delay-{{index + 5}}"
            wx:for="{{recommendList}}"
            wx:key="_id"
            bindtap="goToFlowerDetail"
            data-id="{{item._id}}"
          >
            <view class="recommend-card-thumb" style="background-color: {{item.coverImage ? '' : item.thumbBg || 'var(--bg-green-light)'}};">
              <image wx:if="{{item.coverImage}}" src="{{item.coverImage}}" mode="aspectFill" class="recommend-card-img" />
              <icon wx:else name="leaf" size="xl" />
            </view>
            <view class="recommend-card-body">
              <view class="recommend-card-top">
                <text class="recommend-card-name">{{item.name}}</text>
                <view class="tag tag-{{item.tagColor || 'green'}}">{{item.category}}</view>
              </view>
              <text class="recommend-card-desc text-ellipsis-2">{{item.description}}</text>
              <view class="recommend-card-meta">
                <text class="meta-label">养护难度</text>
                <view class="star-row">
                  <text class="star filled" wx:for="{{item.difficulty}}" wx:for-item="s" wx:key="*this">★</text>
                  <text class="star empty" wx:for="{{5 - item.difficulty}}" wx:for-item="s" wx:key="*this">☆</text>
                </view>
              </view>
            </view>
            <view class="recommend-card-arrow">
              <icon name="arrow" size="sm" color="var(--text-hint)" />
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:else>
          <icon name="flower" size="xl" />
          <text class="empty-title">暂无推荐</text>
          <text class="empty-text">快去探索花卉百科吧</text>
          <view class="empty-action">
            <view class="btn-primary btn-sm" bindtap="goToEncyclopedia">去看看</view>
          </view>
        </view>
      </view>

    </view>
  </scroll-view>
</view>

/* pages/index/index.wxss - 首页样式 */
.home-page {
  padding: 0 32rpx 48rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-round);
  padding: 20rpx 32rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-placeholder {
  color: var(--text-hint);
  font-size: var(--font-md);
  flex: 1;
}

/* 每日养护小贴士 */
.daily-tip-card {
  position: relative;
  background: linear-gradient(135deg, #EDF7ED 0%, #D7ECD9 100%);
  border-radius: var(--border-radius-xl);
  padding: 32rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  overflow: hidden;
}

.tip-content-area {
  flex: 1;
  z-index: 1;
}

.tip-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tip-icon-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-icon-emoji {
  font-size: 28rpx;
}

.tip-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
}

.tip-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.8;
  display: block;
  padding-right: 80rpx;
}

.tip-decoration {
  position: absolute;
  right: 24rpx;
  bottom: 16rpx;
  opacity: 0.25;
}

.tip-deco-emoji {
  font-size: 120rpx;
}

/* 季节养护 */
.season-section {
  margin-bottom: 40rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.season-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 20rpx;
  padding: 8rpx 0;
}

.season-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  border-radius: var(--border-radius-lg);
  transition: transform var(--transition-fast);
}

.season-card:active {
  transform: scale(0.95);
}

.season-card-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.season-card-title {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

/* 推荐花卉区块 */
.recommend-section {
  margin-top: 8rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  color: var(--color-primary);
  font-size: var(--font-sm);
}

.more-arrow {
  font-size: var(--font-lg);
  margin-left: 4rpx;
  font-weight: 300;
}

/* 推荐花卉 - 垂直列表 */
.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recommend-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast);
}

.recommend-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.recommend-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--border-radius-md);
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-emoji {
  font-size: 64rpx;
}

.recommend-info {
  flex: 1;
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.recommend-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recommend-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.recommend-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--border-radius-round);
  font-weight: 500;
}

/* 分类标签不同颜色 */
.tag-green {
  color: #388E3C;
  background-color: #E8F5E9;
}

.tag-orange {
  color: #E65100;
  background-color: #FFF3E0;
}

.tag-pink {
  color: #AD1457;
  background-color: #FCE4EC;
}

.tag-purple {
  color: #6A1B9A;
  background-color: #F3E5F5;
}

.tag-blue {
  color: #1565C0;
  background-color: #E3F2FD;
}

.recommend-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-meta {
  display: flex;
  align-items: center;
}

.meta-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.star {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.star.filled {
  color: #4CAF50;
}

.star.empty {
  color: #D0D0D0;
}

.recommend-arrow {
  font-size: 40rpx;
  color: var(--text-hint);
  font-weight: 300;
  flex-shrink: 0;
}

/* 空状态 */
.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: var(--text-hint);
  font-size: var(--font-md);
}

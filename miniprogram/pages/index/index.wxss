/* pages/index/index.wxss - 首页样式 */
.container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.search-bar {
  background-color: var(--bg-grey);
  border-radius: var(--border-radius-round);
  padding: 20rpx 32rpx;
  margin-bottom: 24rpx;
}

.search-placeholder {
  color: var(--text-hint);
  font-size: var(--font-md);
}

.daily-tip {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border: none;
}

.tip-label {
  font-size: var(--font-sm);
  color: var(--color-primary-dark);
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.tip-content {
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: 1.6;
}

/* 季节养护速览 */
.season-tips {
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.season-tip-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  text-align: center;
}

.season-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.season-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.season-desc {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.section {
  margin-top: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: var(--font-sm);
}

/* 推荐花卉卡片 */
.recommend-card {
  display: flex;
  flex-direction: row;
  padding: 0;
  overflow: hidden;
}

.recommend-cover {
  width: 220rpx;
  min-height: 220rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-emoji {
  font-size: 80rpx;
}

.recommend-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.recommend-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.recommend-category {
  font-size: var(--font-xs);
  display: block;
  margin-top: 4rpx;
}

.recommend-desc {
  font-size: var(--font-sm);
  line-height: 1.5;
  margin-top: 8rpx;
}

.difficulty-row {
  display: flex;
  align-items: center;
}

.difficulty-label {
  font-size: var(--font-xs);
}

.difficulty-stars {
  font-size: var(--font-xs);
}

.empty-placeholder {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-hint);
  font-size: var(--font-sm);
}

/* pages/index/index.wxss - 首页样式（精美化） */
@import '/styles/animation.wxss';

.home-page {
  padding: 0 var(--spacing-lg) var(--spacing-xl);
}

/* ==================== 搜索栏 ==================== */

.home-search {
  margin-bottom: var(--spacing-lg);
}

.home-search-inner {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-round);
  padding: 22rpx 32rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.home-search-inner:active {
  border-color: var(--color-primary-light);
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.08);
  transform: scale(0.99);
}

.home-search-text {
  color: var(--text-hint);
  font-size: var(--font-md);
  flex: 1;
}

/* ==================== 每日贴士卡片 ==================== */

.tip-card {
  position: relative;
  background: var(--gradient-hero);
  border-radius: var(--border-radius-xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-xl);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  overflow: hidden;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(76, 175, 80, 0.1);
}

.tip-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.08);
}

.tip-card::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: 30%;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.05);
}

.tip-icon-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-card-body {
  flex: 1;
  z-index: var(--z-base);
  padding-right: var(--spacing-lg);
}

.tip-card-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}

.tip-card-title {
  font-size: var(--font-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary-dark);
}

.tip-card-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-loose);
  display: block;
}

.tip-card-deco {
  position: absolute;
  right: var(--spacing-md);
  bottom: var(--spacing-sm);
  opacity: 0.15;
  z-index: 0;
  animation: float 4s ease-in-out infinite;
}

/* ==================== Section 通用 ==================== */

.section {
  margin-bottom: var(--spacing-xl);
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.section-more-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: var(--color-primary);
  font-size: var(--font-sm);
  padding: 8rpx 16rpx;
  border-radius: var(--border-radius-round);
  background-color: var(--bg-green-light);
  transition: all var(--transition-fast);
}

.more-arrow {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-primary);
  line-height: 1;
  margin-left: 2rpx;
}

.section-more-btn:active {
  opacity: 0.7;
  transform: scale(0.96);
}

/* ==================== 季节养护网格 ==================== */

.season-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
  margin-top: var(--spacing-sm);
}

.season-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) var(--spacing-sm);
  border-radius: var(--border-radius-xl);
  transition: transform var(--transition-bounce), box-shadow var(--transition-fast);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

.season-card::after {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
}

.season-card:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.season-card-icon-wrap {
  margin-bottom: var(--spacing-sm);
}

.season-card-title {
  font-size: var(--font-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 4rpx;
}

.season-card-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  text-align: center;
}

/* ==================== 推荐花卉列表 ==================== */

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.recommend-card {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-xl);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  border: 2rpx solid var(--border-light);
}

.recommend-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-lg);
}

.recommend-card-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--border-radius-lg);
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.recommend-card-img {
  width: 100%;
  height: 100%;
}

.recommend-card-body {
  flex: 1;
  padding: 0 var(--spacing-sm) 0 var(--spacing-md);
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  gap: var(--spacing-xs);
}

.recommend-card-top {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}

.recommend-card-name {
  font-size: var(--font-lg);
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.recommend-card-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-normal);
}

.recommend-card-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.meta-label {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.star-row {
  display: flex;
  align-items: center;
}

.star {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.star.filled {
  color: var(--color-primary);
}

.star.empty {
  color: var(--border-color);
}

.recommend-card-arrow {
  flex-shrink: 0;
  padding-left: var(--spacing-xs);
}

.card-arrow-text {
  font-size: 28rpx;
  color: var(--border-color);
  font-weight: 300;
  line-height: 1;
}

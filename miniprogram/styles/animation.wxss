/* animation.wxss - 全局动画库 */
/* 在需要动画效果的页面中 @import 此文件即可使用 */

/* ==================== 关键帧定义 ==================== */

/* 淡入 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 从下方淡入 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 从上方淡入 */
@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 从左侧淡入 */
@keyframes fadeInLeft {
  from { opacity: 0; transform: translateX(-40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* 从右侧淡入 */
@keyframes fadeInRight {
  from { opacity: 0; transform: translateX(40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* 缩放淡入 */
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}

/* 弹跳缩放 */
@keyframes bounceIn {
  0% { opacity: 0; transform: scale(0.3); }
  50% { opacity: 1; transform: scale(1.05); }
  70% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

/* 脉冲呼吸 */
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.08); opacity: 0.8; }
}

/* 持续旋转 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 水波纹扩散 */
@keyframes ripple {
  0% { transform: scale(0.8); opacity: 0.6; }
  100% { transform: scale(2.2); opacity: 0; }
}

/* 摇晃提醒 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-8rpx); }
  40% { transform: translateX(8rpx); }
  60% { transform: translateX(-6rpx); }
  80% { transform: translateX(6rpx); }
}

/* 轻微浮动 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* 光晕脉冲 */
@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.1); opacity: 1; }
}

/* 骨架屏闪烁 */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* 打字机光标 */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ==================== 动画应用类 ==================== */

.anim-fade-in {
  animation: fadeIn 0.4s ease both;
}

.anim-fade-in-up {
  animation: fadeInUp 0.5s ease both;
}

.anim-fade-in-down {
  animation: fadeInDown 0.5s ease both;
}

.anim-fade-in-left {
  animation: fadeInLeft 0.4s ease both;
}

.anim-fade-in-right {
  animation: fadeInRight 0.4s ease both;
}

.anim-scale-in {
  animation: scaleIn 0.35s ease both;
}

.anim-bounce-in {
  animation: bounceIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55) both;
}

.anim-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.anim-spin {
  animation: spin 1s linear infinite;
}

.anim-shake {
  animation: shake 0.5s ease both;
}

.anim-float {
  animation: float 3s ease-in-out infinite;
}

.anim-glow {
  animation: glowPulse 2.5s ease-in-out infinite;
}

/* ==================== 骨架屏 ==================== */

.skeleton {
  background: linear-gradient(
    90deg,
    var(--bg-grey) 25%,
    #F5F8F2 50%,
    var(--bg-grey) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--border-radius-sm);
}

.skeleton-circle {
  border-radius: 50%;
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 16rpx;
  border-radius: var(--border-radius-xs);
}

.skeleton-text-short {
  width: 60%;
}

.skeleton-avatar {
  width: 88rpx;
  height: 88rpx;
}

.skeleton-card {
  height: 200rpx;
}

/* ==================== 延迟 ==================== */

.anim-delay-1 { animation-delay: 0.05s; }
.anim-delay-2 { animation-delay: 0.1s; }
.anim-delay-3 { animation-delay: 0.15s; }
.anim-delay-4 { animation-delay: 0.2s; }
.anim-delay-5 { animation-delay: 0.25s; }
.anim-delay-6 { animation-delay: 0.3s; }
.anim-delay-7 { animation-delay: 0.35s; }
.anim-delay-8 { animation-delay: 0.4s; }

/* ==================== 过渡辅助 ==================== */

.trans-all {
  transition: all var(--transition-normal);
}

.trans-fast {
  transition: all var(--transition-fast);
}

.trans-slow {
  transition: all var(--transition-slow);
}

.trans-bounce {
  transition: all var(--transition-bounce);
}

/* variables.wxss - 样式变量 */
page {
  /* 品牌色 */
  --color-primary: #4CAF50;
  --color-primary-light: #81C784;
  --color-primary-dark: #388E3C;
  --color-secondary: #FF9800;
  --color-accent: #E91E63;

  /* 文字颜色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --text-white: #ffffff;

  /* 背景色 */
  --bg-page: #f5f5f5;
  --bg-card: #ffffff;
  --bg-grey: #f0f0f0;

  /* 边框 */
  --border-color: #eeeeee;
  --border-radius-sm: 8rpx;
  --border-radius-md: 16rpx;
  --border-radius-lg: 24rpx;
  --border-radius-round: 999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 字号 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

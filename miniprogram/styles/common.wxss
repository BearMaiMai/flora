/* common.wxss - 全局通用样式类 */

/* ==================== 布局辅助 ==================== */

.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-start { display: flex; justify-content: flex-start; align-items: center; }
.flex-end { display: flex; justify-content: flex-end; align-items: center; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.align-center { align-items: center; }
.align-start { align-items: flex-start; }
.align-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.relative { position: relative; }
.absolute { position: absolute; }
.overflow-hidden { overflow: hidden; }
.w-full { width: 100%; }
.h-full { height: 100%; }

/* ==================== 容器 ==================== */

.container {
  padding: var(--page-padding);
  min-height: 100vh;
}

.page-container {
  padding: 0 var(--page-padding) var(--spacing-xl);
}

.card {
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
  transition: box-shadow var(--transition-fast), transform var(--transition-fast);
}

.card:active {
  box-shadow: var(--shadow-card-hover);
  transform: scale(0.99);
}

.card-flat {
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

/* ==================== 标签 ==================== */

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--border-radius-round);
  font-size: var(--font-xs);
  line-height: 1.6;
  font-weight: var(--font-weight-medium);
}

.tag-green {
  background-color: var(--bg-green-light);
  color: var(--color-primary-dark);
}

.tag-orange {
  background-color: var(--bg-orange-light);
  color: #E65100;
}

.tag-blue {
  background-color: var(--bg-blue-light);
  color: #1565C0;
}

.tag-coral {
  background-color: #FBE9E7;
  color: var(--color-accent);
}

.tag-pink {
  background-color: var(--bg-pink-light);
  color: #AD1457;
}

.tag-purple {
  background-color: var(--bg-purple-light);
  color: #6A1B9A;
}

.tag-red {
  background-color: var(--bg-red-light);
  color: var(--color-danger);
}

.tag-yellow {
  background-color: var(--bg-yellow-light);
  color: #F57F17;
}

/* ==================== 文本 ==================== */

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-green { color: var(--color-primary); }
.text-accent { color: var(--color-accent); }
.text-white { color: var(--text-white); }
.text-bold { font-weight: var(--font-weight-bold); }
.text-semibold { font-weight: var(--font-weight-semibold); }
.text-medium { font-weight: var(--font-weight-medium); }
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-xxl { font-size: var(--font-xxl); }

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.text-ellipsis-3 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.text-line-through {
  text-decoration: line-through;
  color: var(--text-hint);
}

/* ==================== 按钮 ==================== */

.btn-primary {
  background-color: var(--color-primary);
  color: var(--text-white);
  border-radius: var(--border-radius-round);
  padding: 20rpx 48rpx;
  font-size: var(--font-md);
  font-weight: var(--font-weight-medium);
  text-align: center;
  border: none;
  box-shadow: var(--shadow-btn);
  transition: all var(--transition-fast);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary::after { border: none; }

.btn-outline {
  background-color: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--border-radius-round);
  padding: 18rpx 48rpx;
  font-size: var(--font-md);
  text-align: center;
  transition: all var(--transition-fast);
}

.btn-outline:active {
  background-color: var(--bg-green-light);
}

.btn-outline::after { border: none; }

.btn-accent {
  background-color: var(--color-accent);
  color: var(--text-white);
  border-radius: var(--border-radius-round);
  padding: 20rpx 48rpx;
  font-size: var(--font-md);
  font-weight: var(--font-weight-medium);
  text-align: center;
  border: none;
  transition: all var(--transition-fast);
}

.btn-accent:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-accent::after { border: none; }

.btn-sm {
  padding: 12rpx 28rpx;
  font-size: var(--font-sm);
}

.btn-lg {
  padding: 28rpx 64rpx;
  font-size: var(--font-lg);
}

.btn-block {
  width: 100%;
  display: flex;
  justify-content: center;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 轻量级文字按钮 */
.btn-text {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: var(--color-primary);
  font-size: var(--font-sm);
  padding: 8rpx 20rpx;
  border-radius: var(--border-radius-round);
  background-color: var(--bg-green-light);
  font-weight: var(--font-weight-medium);
  transition: opacity var(--transition-fast);
}

.btn-text:active {
  opacity: 0.7;
}

/* ==================== 间距 ==================== */

.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }
.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.px-md { padding-left: var(--spacing-md); padding-right: var(--spacing-md); }
.py-md { padding-top: var(--spacing-md); padding-bottom: var(--spacing-md); }

.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }

/* ==================== 分割线 ==================== */

.divider {
  width: 100%;
  height: 1rpx;
  background-color: var(--border-color);
  margin: var(--spacing-sm) 0;
}

.divider-light {
  width: 100%;
  height: 1rpx;
  background-color: var(--border-light);
  margin: var(--spacing-sm) 0;
}

/* ==================== 安全区域 ==================== */

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: env(safe-area-inset-top);
}

/* ==================== 页面标题区块 ==================== */

.page-header {
  margin-bottom: var(--spacing-lg);
}

.page-title {
  font-size: var(--font-xxl);
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.page-subtitle {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

/* ==================== Section 区块 ==================== */

.section {
  margin-bottom: var(--spacing-lg);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.section-more {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

/* ==================== 搜索栏 ==================== */

.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--bg-grey);
  border-radius: var(--border-radius-round);
  padding: 18rpx 28rpx;
  margin-bottom: var(--spacing-md);
  transition: box-shadow var(--transition-fast);
}

.search-bar:focus-within {
  box-shadow: 0 0 0 2rpx var(--color-primary-light);
}

.search-bar-icon {
  margin-right: 12rpx;
  font-size: var(--icon-sm);
  color: var(--text-hint);
}

.search-bar-input {
  font-size: var(--font-md);
  flex: 1;
  color: var(--text-primary);
}

/* ==================== 分类筛选（横向滚动 pill） ==================== */

.filter-scroll {
  white-space: nowrap;
  margin-bottom: var(--spacing-md);
  padding: 4rpx 0;
}

.filter-item {
  display: inline-block;
  padding: 14rpx 32rpx;
  margin-right: var(--spacing-sm);
  border-radius: var(--border-radius-round);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background-color: var(--bg-card);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.filter-item.active {
  background-color: var(--color-primary);
  color: var(--text-white);
  box-shadow: var(--shadow-btn);
}

/* ==================== 头像 ==================== */

.avatar {
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-xs {
  width: var(--avatar-xs);
  height: var(--avatar-xs);
}

.avatar-sm {
  width: var(--avatar-sm);
  height: var(--avatar-sm);
}

.avatar-md {
  width: var(--avatar-md);
  height: var(--avatar-md);
}

.avatar-lg {
  width: var(--avatar-lg);
  height: var(--avatar-lg);
}

.avatar-xl {
  width: var(--avatar-xl);
  height: var(--avatar-xl);
}

.avatar-green {
  background-color: var(--bg-green-light);
  border: 4rpx solid var(--color-primary-light);
}

.avatar-orange {
  background-color: var(--bg-orange-light);
  border: 4rpx solid var(--color-warning);
}

.avatar-emoji {
  font-size: 48rpx;
}

/* ==================== 徽章 / Badge ==================== */

.badge {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  font-weight: var(--font-weight-semibold);
  border-radius: var(--border-radius-round);
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
}

.badge-accent {
  background-color: var(--color-accent);
  color: var(--text-white);
}

.badge-primary {
  background-color: var(--color-primary);
  color: var(--text-white);
}

.badge-green-light {
  background-color: var(--bg-green-light);
  color: var(--color-primary-dark);
}

.badge-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-accent);
}

/* ==================== 列表项 ==================== */

.list-card {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.list-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.list-card-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--border-radius-md);
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.list-card-body {
  flex: 1;
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.list-card-arrow {
  font-size: 40rpx;
  color: var(--text-hint);
  font-weight: 300;
  flex-shrink: 0;
}

/* ==================== 空状态 ==================== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 160rpx 48rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.8;
}

.empty-title {
  font-size: var(--font-lg);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
  font-weight: var(--font-weight-medium);
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-hint);
  line-height: var(--line-height-loose);
}

.empty-action {
  margin-top: var(--spacing-lg);
}

/* ==================== 加载状态 ==================== */

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: loading-pulse 1.5s ease-in-out infinite;
}

.loading-text {
  font-size: var(--font-md);
  color: var(--text-hint);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* ==================== 底部操作栏 ==================== */

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx var(--spacing-lg);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-card);
  box-shadow: var(--shadow-top);
  gap: 20rpx;
  z-index: var(--z-fixed);
}

/* ==================== 浮动操作按钮 ==================== */

.fab {
  position: fixed;
  right: 48rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  box-shadow: var(--shadow-fab);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: var(--z-fixed);
  transition: transform var(--transition-fast);
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 48rpx;
  color: white;
}

/* ==================== 图片网格 ==================== */

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.image-grid-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
  position: relative;
}

.image-grid-item image {
  width: 100%;
  height: 100%;
}

.image-grid-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--border-radius-sm);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: border-color var(--transition-fast);
}

.image-grid-add:active {
  border-color: var(--color-primary);
}

/* ==================== 时间线 ==================== */

.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  flex-direction: row;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 28rpx;
}

.timeline-dot-primary {
  background-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(76, 175, 80, 0.12);
}

.timeline-dot-accent {
  background-color: var(--color-accent);
  box-shadow: 0 0 0 6rpx rgba(255, 112, 67, 0.12);
}

.timeline-dot-muted {
  background-color: var(--text-hint);
}

.timeline-line {
  width: 3rpx;
  flex: 1;
  background: linear-gradient(180deg, var(--color-primary-light), var(--border-color));
  margin: 8rpx 0;
  min-height: 40rpx;
}

.timeline-content {
  flex: 1;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
}

/* ==================== 圆形图标容器 ==================== */

.icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.icon-circle-sm {
  width: 56rpx;
  height: 56rpx;
}

.icon-circle-lg {
  width: 88rpx;
  height: 88rpx;
}

/* ==================== 两列网格 ==================== */

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

/* ==================== 统计卡片组 ==================== */

.stats-row {
  display: flex;
  gap: var(--spacing-sm);
}

.stat-card {
  flex: 1;
  background-color: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-md) var(--spacing-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.stat-value {
  font-size: var(--font-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* ==================== 毛玻璃效果 ==================== */

.glass {
  background-color: var(--bg-overlay);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

/* ==================== 圆形按钮（导航返回等） ==================== */

.circle-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--bg-overlay);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform var(--transition-fast);
}

.circle-btn:active {
  transform: scale(0.92);
}

/* ==================== 复选/勾选圆 ==================== */

.check-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: var(--font-md);
  color: var(--text-hint);
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.check-circle.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: white;
}

.check-circle:active {
  transform: scale(0.9);
}

/* ==================== 关键帧动画 ==================== */

@keyframes loading-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.7; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.08); opacity: 1; }
}

/* 动画应用类 */
.animate-fade-in {
  animation: fadeIn 0.4s ease forwards;
}

.animate-slide-up {
  animation: slideUp 0.5s ease forwards;
}

.animate-scale-in {
  animation: scaleIn 0.3s ease forwards;
}

/* 延迟应用 */
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }
.delay-5 { animation-delay: 0.5s; }
